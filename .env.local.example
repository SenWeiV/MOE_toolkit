# MOE Toolkit local-only environment defaults
# Copy to .env.local for values that should stay on this machine.

MOE_REMOTE_HOST=<your-ssh-user>@<your-server-host>
MOE_PUBLIC_BASE_URL=http://<your-server-host>:8080
MOE_ADMIN_USERNAME=<admin-username>
MOE_ADMIN_PASSWORD=<admin-password>
MOE_ADMIN_SESSION_SECRET=<admin-session-secret>
